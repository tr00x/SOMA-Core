{
  "name": "soma-ai",
  "version": "0.1.0",
  "description": "SOMA behavioral monitoring SDK for TypeScript/JavaScript AI agents",
  "author": "Tim Hunt <tim@tr00x.dev>",
  "homepage": "https://github.com/tr00x/soma",
  "repository": {
    "type": "git",
    "url": "https://github.com/tr00x/soma.git",
    "directory": "packages/soma-ai"
  },
  "bugs": {
    "url": "https://github.com/tr00x/soma/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ai", "agents", "monitoring", "observability", "soma"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "ai": ">=3.0.0",
    "@langchain/core": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "ai": { "optional": true },
    "@langchain/core": { "optional": true }
  }
}
