{
  "name": "soma-ai",
  "version": "0.1.0",
  "description": "SOMA behavioral monitoring SDK for TypeScript/JavaScript AI agents",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["ai", "agents", "monitoring", "observability", "soma"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "ai": ">=3.0.0",
    "@langchain/core": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "ai": { "optional": true },
    "@langchain/core": { "optional": true }
  }
}
