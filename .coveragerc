[run]
source = soma
omit =
    src/soma/cli/tabs/*
    src/soma/cli/hub.py
    src/soma/cli/main.py
    src/soma/cli/wizard.py
    src/soma/cli/setup_claude.py
    src/soma/hooks/*
    src/soma/daemon.py
    src/soma/inbox.py

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__
    pass
